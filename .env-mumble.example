# Mumble server superuser password
MUMBLE_SUPERUSER_PASSWORD=changeme

# Mumble server password (leave blank for an open server)
MUMBLE_SERVER_PASSWORD=

# Shared secret between Mumble and mumble-rest for Ice communication
MUMBLE_ICE_SECRET=changeme

# Django secret key for mumble-rest (long random string)
MUMBLE_REST_SECRET_KEY=changeme
